{
  "name": "quantavoxel/laravel-bootstrap-component",
  "version": "1.0.0",
  "type": "library",
  "description": "A lightweight Laravel package offering reusable Bootstrap 5 Blade components, optimized asset bundling, and a highly flexible, universal icon integration system.",
  "keywords": [
    "laravel",
    "laravel-component",
    "bootstrap-laravel-component",
    "bootstrap-5",
    "laravel-package",
    "blade-components",
    "universal-icons",
    "icon-integration",
    "iconify-laravel",
    "asset-bundler",
    "ui-framework",
    "quantavoxel"
  ],
  "license": "MIT",
  "authors": [
    {
      "role": "Developer",
      "name": "QuantaVoxel",
      "email": "developer@quantavoxel.digital",
      "homepage": "https://quantavoxel.digital"
    }
  ],
  "autoload": {
    "psr-4": {
      "Quantavoxel\\LaravelBootstrapComponent\\": "src/"
    },
    "files": [
      "src/Helper/funcion.php"
    ]
  },
  "require": {
    "php": "^8.4",
    "illuminate/support": "^13.9",
    "illuminate/view": "^13.9"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Quantavoxel\\LaravelBootstrapComponent\\BootstrapComponentServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "preferred-install": "dist",
    "optimize-autoloader": true
  }
}
